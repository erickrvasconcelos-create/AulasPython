import random

while True:


   

    print("Adivinhe o número!")

    while True:
        print("Dificuldade 1: 50 números")
        print("Dificuldade 2: 100 números")
        print("Dificuldade 3: 500 números")

        escolha = input("Escolha sua dificuldade: ")

        if escolha == "1":
            limite = 50
            break
        elif escolha == "2":
            limite = 100
            break
        elif escolha == "3":
            limite = 500
            break
        else:
            print("Digite uma opção válida.")

    sorteado = random.randint(1, limite)
    tentativas = 0
    
    print(f"Adivinhe o número entre 1 e {limite}!")

    while True:
        try:
            numero = int(input("Insira seu chute: "))

            if not (1 <= numero <= limite):
                print(f"Digite um número entre 1 e {limite}.")
                continue

            tentativas += 1
            distancia = abs(numero - sorteado)

            if numero > sorteado:
                print("Você errou, tente um número mais baixo.")
            elif numero < sorteado:
                print("Você errou, tente um número mais alto.")
            else:
                print(f"Você acertou! O número era {sorteado}.")
                print(f"Você precisou de {tentativas} tentativas!")
                novamente = input("você acertou, quer tentar novamente? (S/N)")
                if novamente != "S":
                    print("Obrigado Por Jogar")
                    exit()
                else:
                    break
            if distancia <= 5:
                print("Muito perto!")
            elif distancia <= 10:
                print("Perto!")
            else:
                print("Longe!")
                
            
           
        except ValueError:
            print("Digite um número válido.")

 

 