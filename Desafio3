while True:
    notas = []

    while True:
        try:
            entrada = input("Digite uma nota ou 'fim': ")

            if entrada == "fim":
                break

            nota = float(entrada)

            if nota < 0 or nota > 10:
                print("Número inválido")
                continue

            notas.append(nota)

        except ValueError:
            print("Nota inválida, digite novamente")

    if len(notas) == 0:
        print("Nenhuma nota foi digitada.")
    else:
        media = sum(notas) / len(notas)

        if media >= 7:
            resultado = "aprovado"
        else:
            resultado = "reprovado"
            pontos = 7 - media
            print(f"Você precisa de {pontos:.2f} pontos pra passar")

        print(f"Suas notas são {notas}, sua média é {media:.2f}, e você foi {resultado}")
        print(f"Sua maior nota foi {max(notas)} e sua menor {min(notas)}")

    voltar = input("Digite 'sair' para fechar ou qualquer tecla para reiniciar: ")
    if voltar == "sair":
        break